  <example>
    <content>proposal vmr2 {
    authentication-method pre-shared-keys;
    dh-group group14;
    authentication-algorithm sha-256;
    encryption-algorithm aes-256-cbc;
    lifetime-seconds 7200;
}
policy vmr2 {
    mode main;
    proposals vmr2;
    pre-shared-key ascii-text &quot;$9$OY9lISeLX-Y2as2/tuOcSWLxdb2ikPT39oJqfQ3puhSrlvLbwg4aU4aPQ39OBSreWX-ZGifT3db4ZjkTQ0BIcrvY2aUjqNdGiqfn6IEcSeWws4Di.Vw&quot;; ## SECRET-DATA
}
gateway vmrGateway {
    ike-policy vmr2;
    address 1.1.1.1;
    local-identity hostname fregrgr;
    remote-identity inet 1.1.1.1;
    external-interface fxp0;
    version v2-only;
}
</content>
