  <example>
    <content>proposal vmrIKE {
    authentication-method pre-shared-keys;
    dh-group group14;
    authentication-algorithm sha-256;
    encryption-algorithm aes-256-cbc;
    lifetime-seconds 7200;
}
policy vmrIKE {
    mode main;
    proposals vmrIKE;
    pre-shared-key ascii-text &quot;$9$QJLK36AB1hyK8tuyKWLVb.P5znCIRSevL9ABEyeXxgoJZDkQz6pu1Fn1hcr8L7-VwYoiHm5z6JGmT36u0LxNdb2oaUmPQdbJDHkTQ/CtO1h&quot;; ## SECRET-DATA
}
</content>
  </example>
  <command name="IMPORT">
    <operation><![CDATA[ show security ike ]]></operation>
    <parser>
      <section>
        <regexp>@^policy\s+(?&lt;object_id&gt;\S+)@</regexp>
        <regexp>@^proposal\s+(?&lt;object_id&gt;\S+)@</regexp>
      </section>
      <lines>
        <line>
          <regexp>@^\s+pre-shared-key ascii-text\s+&quot;(?&lt;peer_preshared&gt;[^&quot;]+)@</regexp>
          <xpath></xpath>
        </line>
        <ignore>
          <regexp>@^\s+mode.*@</regexp>
        </ignore>
        <ignore>
          <regexp>@^\s+proposals.*@</regexp>
        </ignore>
      </lines>
    </parser>
  </command>
  <command name="CREATE">
    <operation><![CDATA[set security ike proposal {$params.object_id} authentication-algorithm sha-256
set security ike proposal {$params.object_id} authentication-method pre-shared-keys
set security ike proposal {$params.object_id} dh-group group14
set security ike proposal {$params.object_id} encryption-algorithm aes-256-cbc
set security ike proposal {$params.object_id} lifetime-seconds 7200

set security ike policy {$params.object_id} mode main
set security ike policy {$params.object_id} proposals {$params.object_id}
set security ike policy {$params.object_id} pre-shared-key ascii-text {$params.peer_preshared}]]></operation>
  </command>
